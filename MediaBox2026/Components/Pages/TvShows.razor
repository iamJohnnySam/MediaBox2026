@page "/tvshows"
@using MediaBox2026.Services
@using MediaBox2026.Models
@inject MediaDatabase Db
@inject MediaBoxState State
@implements IDisposable

<PageTitle>TV Shows</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📺 TV Shows (@filteredShows.Count)</h2>
    <input type="text" class="form-control w-25" placeholder="Search..." @bind="searchTerm" @bind:event="oninput" />
</div>

@if (filteredShows.Count == 0)
{
    <div class="alert alert-info">No TV shows found. Run a media scan from Settings.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Year</th>
                    <th>Latest Season</th>
                    <th>Episodes</th>
                    <th>Path</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var show in filteredShows)
                {
                    <tr>
                        <td><strong>@show.Name</strong></td>
                        <td>@(show.Year?.ToString() ?? "—")</td>
                        <td>Season @show.LatestSeason</td>
                        <td>@show.Episodes.Count</td>
                        <td class="text-muted small">@show.FolderPath</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<TvShow> allShows = [];
    private string searchTerm = "";

    private List<TvShow> filteredShows => string.IsNullOrWhiteSpace(searchTerm)
        ? allShows
        : allShows.Where(s => s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        LoadData();
        State.OnChange += OnStateChanged;
    }

    private void LoadData() => allShows = Db.TvShows.FindAll().OrderBy(s => s.Name).ToList();

    private void OnStateChanged() => InvokeAsync(() => { LoadData(); StateHasChanged(); });

    public void Dispose() => State.OnChange -= OnStateChanged;
}
